import UIKit

// MARK: - AvatarItemViewDelegate
protocol AvatarItemViewDelegate: AnyObject {
    func avatarItemViewDidTap(_ view: AvatarItemView, item: AvatarItem)
}

// MARK: - AvatarItemView
class AvatarItemView: UIView {
    
    // MARK: - Properties
    weak var delegate: AvatarItemViewDelegate?
    private var item: AvatarItem?
    
    // MARK: - UI Components
    private let containerView = UIView()
    private let imageView = UIImageView()
    private let nameLabel = UILabel()
    private let lockIconView = UIImageView()
    
    // MARK: - Init
    override init(frame: CGRect) {
        super.init(frame: frame)
        setupUI()
    }
    
    required init?(coder: NSCoder) {
        fatalError("init(coder:) has not been implemented")
    }
    
    // MARK: - Setup UI
    private func setupUI() {
        addSubview(containerView)
        containerView.translatesAutoresizingMaskIntoConstraints = false
        containerView.backgroundColor = UIColor(hexCode: "#FAFAFA")
        containerView.layer.cornerRadius = 12
        containerView.layer.borderWidth = 2
        
        // Image View
        containerView.addSubview(imageView)
        imageView.translatesAutoresizingMaskIntoConstraints = false
        imageView.contentMode = .scaleAspectFit
        
        // Name Label
        containerView.addSubview(nameLabel)
        nameLabel.translatesAutoresizingMaskIntoConstraints = false
        nameLabel.font = .systemFont(ofSize: 12)
        nameLabel.textAlignment = .center
        
        // Lock Icon (for not owned items)
        containerView.addSubview(lockIconView)
        lockIconView.translatesAutoresizingMaskIntoConstraints = false
        lockIconView.image = UIImage(systemName: "lock.fill")
        lockIconView.tintColor = UIColor(hexCode: "#999999")
        lockIconView.isHidden = true
        
        // Tap Gesture
        let tapGesture = UITapGestureRecognizer(target: self, action: #selector(handleTap))
        containerView.addGestureRecognizer(tapGesture)
        
        // Constraints
        NSLayoutConstraint.activate([
            containerView.topAnchor.constraint(equalTo: topAnchor),
            containerView.leadingAnchor.constraint(equalTo: leadingAnchor),
            containerView.trailingAnchor.constraint(equalTo: trailingAnchor),
            containerView.bottomAnchor.constraint(equalTo: bottomAnchor),
            
            imageView.topAnchor.constraint(equalTo: containerView.topAnchor, constant: 10),
            imageView.leadingAnchor.constraint(equalTo: containerView.leadingAnchor, constant: 10),
            imageView.trailingAnchor.constraint(equalTo: containerView.trailingAnchor, constant: -10),
            imageView.bottomAnchor.constraint(equalTo: nameLabel.topAnchor, constant: -5),
            
            nameLabel.leadingAnchor.constraint(equalTo: containerView.leadingAnchor, constant: 5),
            nameLabel.trailingAnchor.constraint(equalTo: containerView.trailingAnchor, constant: -5),
            nameLabel.bottomAnchor.constraint(equalTo: containerView.bottomAnchor, constant: -10),
            nameLabel.heightAnchor.constraint(equalToConstant: 15),
            
            lockIconView.topAnchor.constraint(equalTo: containerView.topAnchor, constant: 8),
            lockIconView.trailingAnchor.constraint(equalTo: containerView.trailingAnchor, constant: -8),
            lockIconView.widthAnchor.constraint(equalToConstant: 20),
            lockIconView.heightAnchor.constraint(equalToConstant: 20)
        ])
    }
    
    // MARK: - Configure
    func configure(with item: AvatarItem) {
        self.item = item
        
        // Name
        nameLabel.text = item.name
        
        // Image
        if let imageName = item.imageName {
            imageView.image = UIImage(named: imageName)
        } else if let imageURL = item.imageURL {
            // TODO: 네트워크 이미지 로딩 구현
            imageView.image = UIImage(systemName: "photo")
        }
        
        // Status에 따른 UI 업데이트
        switch item.status {
        case .equipped:
            containerView.layer.borderColor = UIColor(hexCode: "#7AE87A").cgColor
            containerView.backgroundColor = UIColor(hexCode: "#FAFAFA")
            nameLabel.textColor = UIColor(hexCode: "#333333")
            lockIconView.isHidden = true
            imageView.alpha = 1.0
            
        case .owned:
            containerView.layer.borderColor = UIColor.black.cgColor
            containerView.backgroundColor = UIColor(hexCode: "#FAFAFA")
            nameLabel.textColor = UIColor.black
            lockIconView.isHidden = true
            imageView.alpha = 1.0
            
        case .notOwned:
            containerView.layer.borderColor = UIColor(hexCode: "#888888").cgColor
            containerView.backgroundColor = UIColor(hexCode: "#FAFAFA")
            nameLabel.textColor = UIColor(hexCode: "#999999")
            lockIconView.isHidden = false
            imageView.alpha = 0.5
        }
    }
    
    // MARK: - Actions
    @objc private func handleTap() {
        guard let item = item else { return }
        delegate?.avatarItemViewDidTap(self, item: item)
    }
}
