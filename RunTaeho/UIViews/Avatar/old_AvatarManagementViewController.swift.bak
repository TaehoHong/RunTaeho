import UIKit

class AvatarManagementViewController: UIViewController {
    
    // MARK: - Properties
    private let viewModel = AvatarManagementViewModel()
    
    // MARK: - UI Components
    private let headerView = UIView()
    private let backButton = UIButton()
    private let titleLabel = UILabel()
    private let pointsView = UIView()
    private let pointsIconView = UIView()
    private let pointsLabel = UILabel()
    
    private let previewContainer = UIView()
    private let previewLabel = UILabel()
    
    private let categoryTabView = UIView()
    private var categoryButtons: [UIButton] = []
    
    private let itemsScrollView = UIScrollView()
    private let itemsContainerView = UIView()
    private var itemViews: [AvatarItemView] = []
    
    private let bottomButtonContainer = UIView()
    private let cancelButton = UIButton()
    private let confirmButton = UIButton()
    
    // MARK: - Lifecycle
    override func viewDidLoad() {
        super.viewDidLoad()
        setupUI()
        bindViewModel()
    }
    
    // MARK: - Setup UI
    private func setupUI() {
        view.backgroundColor = UIColor(hexCode: "#FAFAFA")
        
        setupHeader()
        setupPreviewContainer()
        setupCategoryTabs()
        setupItemsScrollView()
        setupBottomButtons()
        
        setupConstraints()
    }
    
    private func setupHeader() {
        view.addSubview(headerView)
        headerView.translatesAutoresizingMaskIntoConstraints = false
        
        // Back Button
        headerView.addSubview(backButton)
        backButton.translatesAutoresizingMaskIntoConstraints = false
        backButton.setTitle("<", for: .normal)
        backButton.setTitleColor(.black, for: .normal)
        backButton.titleLabel?.font = .systemFont(ofSize: 20)
        backButton.addTarget(self, action: #selector(backButtonTapped), for: .touchUpInside)
        
        // Title
        headerView.addSubview(titleLabel)
        titleLabel.translatesAutoresizingMaskIntoConstraints = false
        titleLabel.text = "아바타"
        titleLabel.font = UIFont(name: "BM JUA_TTF", size: 24) ?? .boldSystemFont(ofSize: 24)
        titleLabel.textAlignment = .center
        
        // Points View
        headerView.addSubview(pointsView)
        pointsView.translatesAutoresizingMaskIntoConstraints = false
        
        // Points Icon
        pointsView.addSubview(pointsIconView)
        pointsIconView.translatesAutoresizingMaskIntoConstraints = false
        pointsIconView.backgroundColor = UIColor(hexCode: "#7BE87B")
        pointsIconView.layer.cornerRadius = 10.5
        
        let pointsIconLabel = UILabel()
        pointsIconView.addSubview(pointsIconLabel)
        pointsIconLabel.translatesAutoresizingMaskIntoConstraints = false
        pointsIconLabel.text = "P"
        pointsIconLabel.textColor = .white
        pointsIconLabel.font = .boldSystemFont(ofSize: 12)
        
        // Points Label
        pointsView.addSubview(pointsLabel)
        pointsLabel.translatesAutoresizingMaskIntoConstraints = false
        pointsLabel.text = "10,000"
        pointsLabel.font = UIFont(name: "BM JUA_TTF", size: 25) ?? .boldSystemFont(ofSize: 25)
        
        NSLayoutConstraint.activate([
            // Header
            headerView.topAnchor.constraint(equalTo: view.safeAreaLayoutGuide.topAnchor),
            headerView.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            headerView.trailingAnchor.constraint(equalTo: view.trailingAnchor),
            headerView.heightAnchor.constraint(equalToConstant: 50),
            
            // Back Button
            backButton.leadingAnchor.constraint(equalTo: headerView.leadingAnchor, constant: 20),
            backButton.centerYAnchor.constraint(equalTo: headerView.centerYAnchor),
            backButton.widthAnchor.constraint(equalToConstant: 44),
            backButton.heightAnchor.constraint(equalToConstant: 44),
            
            // Title
            titleLabel.centerXAnchor.constraint(equalTo: headerView.centerXAnchor),
            titleLabel.centerYAnchor.constraint(equalTo: headerView.centerYAnchor),
            
            // Points View
            pointsView.trailingAnchor.constraint(equalTo: headerView.trailingAnchor, constant: -20),
            pointsView.centerYAnchor.constraint(equalTo: headerView.centerYAnchor),
            
            // Points Icon
            pointsIconView.leadingAnchor.constraint(equalTo: pointsView.leadingAnchor),
            pointsIconView.centerYAnchor.constraint(equalTo: pointsView.centerYAnchor),
            pointsIconView.widthAnchor.constraint(equalToConstant: 21),
            pointsIconView.heightAnchor.constraint(equalToConstant: 21),
            
            pointsIconLabel.centerXAnchor.constraint(equalTo: pointsIconView.centerXAnchor),
            pointsIconLabel.centerYAnchor.constraint(equalTo: pointsIconView.centerYAnchor),
            
            // Points Label
            pointsLabel.leadingAnchor.constraint(equalTo: pointsIconView.trailingAnchor, constant: 5),
            pointsLabel.centerYAnchor.constraint(equalTo: pointsView.centerYAnchor),
            pointsLabel.trailingAnchor.constraint(equalTo: pointsView.trailingAnchor)
        ])
    }
    
    private func setupPreviewContainer() {
        view.addSubview(previewContainer)
        previewContainer.translatesAutoresizingMaskIntoConstraints = false
        previewContainer.backgroundColor = .white
        
        previewContainer.addSubview(previewLabel)
        previewLabel.translatesAutoresizingMaskIntoConstraints = false
        previewLabel.text = "Unity View 추가 예정"
        previewLabel.font = UIFont(name: "BM JUA_TTF", size: 22) ?? .systemFont(ofSize: 22)
        previewLabel.textAlignment = .center
        
        NSLayoutConstraint.activate([
            previewLabel.centerXAnchor.constraint(equalTo: previewContainer.centerXAnchor),
            previewLabel.centerYAnchor.constraint(equalTo: previewContainer.centerYAnchor)
        ])
    }
    
    private func setupCategoryTabs() {
        view.addSubview(categoryTabView)
        categoryTabView.translatesAutoresizingMaskIntoConstraints = false
        categoryTabView.backgroundColor = .white
        
        let categories = AvatarCategory.allCases
        let stackView = UIStackView()
        stackView.translatesAutoresizingMaskIntoConstraints = false
        stackView.axis = .horizontal
        stackView.distribution = .fillEqually
        stackView.spacing = 0
        
        categoryTabView.addSubview(stackView)
        
        for (index, category) in categories.enumerated() {
            let button = UIButton()
            button.setTitle(category.displayName, for: .normal)
            button.titleLabel?.font = .systemFont(ofSize: 18, weight: index == 0 ? .semibold : .regular)
            button.backgroundColor = index == 0 ? UIColor(hexCode: "#7AE87A") : UIColor(hexCode: "#F2F2F2")
            button.setTitleColor(index == 0 ? .black : UIColor(hexCode: "#666666"), for: .normal)
            button.tag = index
            button.addTarget(self, action: #selector(categoryButtonTapped(_:)), for: .touchUpInside)
            
            categoryButtons.append(button)
            stackView.addArrangedSubview(button)
        }
        
        NSLayoutConstraint.activate([
            stackView.leadingAnchor.constraint(equalTo: categoryTabView.leadingAnchor, constant: 20),
            stackView.trailingAnchor.constraint(equalTo: categoryTabView.trailingAnchor, constant: -20),
            stackView.topAnchor.constraint(equalTo: categoryTabView.topAnchor, constant: 5),
            stackView.bottomAnchor.constraint(equalTo: categoryTabView.bottomAnchor, constant: -5),
            stackView.heightAnchor.constraint(equalToConstant: 50)
        ])
    }
    
    private func setupItemsScrollView() {
        view.addSubview(itemsScrollView)
        itemsScrollView.translatesAutoresizingMaskIntoConstraints = false
        itemsScrollView.backgroundColor = .white
        
        itemsScrollView.addSubview(itemsContainerView)
        itemsContainerView.translatesAutoresizingMaskIntoConstraints = false
        
        NSLayoutConstraint.activate([
            itemsContainerView.leadingAnchor.constraint(equalTo: itemsScrollView.leadingAnchor),
            itemsContainerView.trailingAnchor.constraint(equalTo: itemsScrollView.trailingAnchor),
            itemsContainerView.topAnchor.constraint(equalTo: itemsScrollView.topAnchor),
            itemsContainerView.bottomAnchor.constraint(equalTo: itemsScrollView.bottomAnchor),
            itemsContainerView.widthAnchor.constraint(equalTo: itemsScrollView.widthAnchor)
        ])
    }
    
    private func setupBottomButtons() {
        view.addSubview(bottomButtonContainer)
        bottomButtonContainer.translatesAutoresizingMaskIntoConstraints = false
        bottomButtonContainer.backgroundColor = .white
        
        // Cancel Button
        bottomButtonContainer.addSubview(cancelButton)
        cancelButton.translatesAutoresizingMaskIntoConstraints = false
        cancelButton.setTitle("취소", for: .normal)
        cancelButton.setTitleColor(.black, for: .normal)
        cancelButton.titleLabel?.font = UIFont(name: "BM JUA_TTF", size: 22) ?? .systemFont(ofSize: 22)
        cancelButton.backgroundColor = UIColor(hexCode: "#D9D9D9")
        cancelButton.layer.cornerRadius = 5
        cancelButton.addTarget(self, action: #selector(cancelButtonTapped), for: .touchUpInside)
        
        // Confirm Button
        bottomButtonContainer.addSubview(confirmButton)
        confirmButton.translatesAutoresizingMaskIntoConstraints = false
        confirmButton.setTitle("확인", for: .normal)
        confirmButton.setTitleColor(.black, for: .normal)
        confirmButton.titleLabel?.font = UIFont(name: "BM JUA_TTF", size: 22) ?? .systemFont(ofSize: 22)
        confirmButton.backgroundColor = UIColor(hexCode: "#7AE87A")
        confirmButton.layer.cornerRadius = 5
        confirmButton.addTarget(self, action: #selector(confirmButtonTapped), for: .touchUpInside)
        
        NSLayoutConstraint.activate([
            cancelButton.leadingAnchor.constraint(equalTo: bottomButtonContainer.leadingAnchor, constant: 20),
            cancelButton.topAnchor.constraint(equalTo: bottomButtonContainer.topAnchor, constant: 10),
            cancelButton.widthAnchor.constraint(equalToConstant: 170),
            cancelButton.heightAnchor.constraint(equalToConstant: 40),
            
            confirmButton.trailingAnchor.constraint(equalTo: bottomButtonContainer.trailingAnchor, constant: -20),
            confirmButton.topAnchor.constraint(equalTo: bottomButtonContainer.topAnchor, constant: 10),
            confirmButton.widthAnchor.constraint(equalToConstant: 170),
            confirmButton.heightAnchor.constraint(equalToConstant: 40)
        ])
    }
    
    private func setupConstraints() {
        NSLayoutConstraint.activate([
            // Preview Container
            previewContainer.topAnchor.constraint(equalTo: headerView.bottomAnchor, constant: 20),
            previewContainer.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            previewContainer.trailingAnchor.constraint(equalTo: view.trailingAnchor),
            previewContainer.heightAnchor.constraint(equalToConstant: 300),
            
            // Category Tabs
            categoryTabView.topAnchor.constraint(equalTo: previewContainer.bottomAnchor, constant: 20),
            categoryTabView.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            categoryTabView.trailingAnchor.constraint(equalTo: view.trailingAnchor),
            categoryTabView.heightAnchor.constraint(equalToConstant: 60),
            
            // Items ScrollView
            itemsScrollView.topAnchor.constraint(equalTo: categoryTabView.bottomAnchor, constant: 20),
            itemsScrollView.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            itemsScrollView.trailingAnchor.constraint(equalTo: view.trailingAnchor),
            itemsScrollView.bottomAnchor.constraint(equalTo: bottomButtonContainer.topAnchor),
            
            // Bottom Buttons
            bottomButtonContainer.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            bottomButtonContainer.trailingAnchor.constraint(equalTo: view.trailingAnchor),
            bottomButtonContainer.bottomAnchor.constraint(equalTo: view.safeAreaLayoutGuide.bottomAnchor),
            bottomButtonContainer.heightAnchor.constraint(equalToConstant: 60)
        ])
    }
    
    // MARK: - Bind ViewModel
    private func bindViewModel() {
        // ViewModel의 상태 변화를 관찰하고 UI 업데이트
        updateItems()
        updatePoints()
    }
    
    private func updateItems() {
        // 기존 아이템 뷰 제거
        itemViews.forEach { $0.removeFromSuperview() }
        itemViews.removeAll()
        
        let items = viewModel.filteredItems
        let itemSize: CGFloat = 120
        let spacing: CGFloat = 15
        let columns = 3
        
        for (index, item) in items.enumerated() {
            let row = index / columns
            let column = index % columns
            
            let itemView = AvatarItemView()
            itemView.configure(with: item)
            itemView.delegate = self
            
            itemsContainerView.addSubview(itemView)
            itemView.translatesAutoresizingMaskIntoConstraints = false
            
            NSLayoutConstraint.activate([
                itemView.leadingAnchor.constraint(equalTo: itemsContainerView.leadingAnchor, 
                                                constant: 20 + CGFloat(column) * (itemSize + spacing)),
                itemView.topAnchor.constraint(equalTo: itemsContainerView.topAnchor, 
                                            constant: 20 + CGFloat(row) * (itemSize + spacing)),
                itemView.widthAnchor.constraint(equalToConstant: itemSize),
                itemView.heightAnchor.constraint(equalToConstant: itemSize)
            ])
            
            itemViews.append(itemView)
        }
        
        // ScrollView content size 업데이트
        let rows = (items.count + columns - 1) / columns
        let contentHeight = CGFloat(rows) * (itemSize + spacing) + 40
        itemsContainerView.heightAnchor.constraint(equalToConstant: contentHeight).isActive = true
    }
    
    private func updatePoints() {
        pointsLabel.text = "\(viewModel.avatarState.userPoints)"
    }
    
    private func updateCategorySelection() {
        for (index, button) in categoryButtons.enumerated() {
            let isSelected = index == viewModel.avatarState.selectedCategory.index
            button.backgroundColor = isSelected ? UIColor(hexCode: "#7AE87A") : UIColor(hexCode: "#F2F2F2")
            button.setTitleColor(isSelected ? .black : UIColor(hexCode: "#666666"), for: .normal)
            button.titleLabel?.font = .systemFont(ofSize: 18, weight: isSelected ? .semibold : .regular)
        }
    }
    
    // MARK: - Actions
    @objc private func backButtonTapped() {
        navigationController?.popViewController(animated: true)
    }
    
    @objc private func categoryButtonTapped(_ sender: UIButton) {
        let categories = AvatarCategory.allCases
        guard sender.tag < categories.count else { return }
        
        viewModel.selectCategory(categories[sender.tag])
        updateCategorySelection()
        updateItems()
    }
    
    @objc private func cancelButtonTapped() {
        viewModel.cancelChanges()
        navigationController?.popViewController(animated: true)
    }
    
    @objc private func confirmButtonTapped() {
        viewModel.confirmChanges()
        navigationController?.popViewController(animated: true)
    }
}

// MARK: - AvatarItemViewDelegate
extension AvatarManagementViewController: AvatarItemViewDelegate {
    func avatarItemViewDidTap(_ view: AvatarItemView, item: AvatarItem) {
        viewModel.selectItem(item)
        
        if viewModel.showPurchaseConfirmation {
            showPurchaseConfirmation()
        } else {
            updateItems()
        }
    }
    
    private func showPurchaseConfirmation() {
        guard let item = viewModel.selectedItemForPurchase else { return }
        
        showPurchaseConfirmation(for: item) {
            self.viewModel.purchaseItem()
            self.updateItems()
            self.updatePoints()
        }
        
        // 팝업이 닫힐 때 상태 초기화
        viewModel.showPurchaseConfirmation = false
        viewModel.selectedItemForPurchase = nil
    }
}

// MARK: - UIColor Extension
extension UIColor {
    convenience init(hex: String) {
        let hex = hex.trimmingCharacters(in: CharacterSet.alphanumerics.inverted)
        var int: UInt64 = 0
        Scanner(string: hex).scanHexInt64(&int)
        let a, r, g, b: UInt64
        switch hex.count {
        case 3: // RGB (12-bit)
            (a, r, g, b) = (255, (int >> 8) * 17, (int >> 4 & 0xF) * 17, (int & 0xF) * 17)
        case 6: // RGB (24-bit)
            (a, r, g, b) = (255, int >> 16, int >> 8 & 0xFF, int & 0xFF)
        case 8: // ARGB (32-bit)
            (a, r, g, b) = (int >> 24, int >> 16 & 0xFF, int >> 8 & 0xFF, int & 0xFF)
        default:
            (a, r, g, b) = (1, 1, 1, 0)
        }
        
        self.init(
            red: Double(r) / 255,
            green: Double(g) / 255,
            blue:  Double(b) / 255,
            alpha: Double(a) / 255
        )
    }
}

// MARK: - AvatarCategory Extension
extension AvatarCategory {
    var index: Int {
        switch self {
        case .hair: return 0
        case .clothes: return 1
        case .shoes: return 2
        }
    }
}
